---
import { ContainerSilk } from '@/components/background-silk/ContainerSilk';
import ContainerCards from '@/components/container-cards.astro';
import Hero from '@/components/Hero.astro';
import { ContainerInfiniteMenu } from '@/components/infinite-menu/ContainerInfiniteMenu';
import LiquidGlass from '@/components/liquid-glass.astro';
import Layout from '@/layouts/layout.astro';
---

<Layout>
  <ContainerSilk client:only='react' />
  <Hero />
  <ContainerInfiniteMenu client:only='react' />
  <ContainerCards />
  <LiquidGlass />
</Layout>

<style is:global>
  [data-theme='light'] .am-container-infinite-menu { display: none; }
  [data-theme='light'] .am-container-cards { display: grid; }
  [data-theme='dark'] .am-container-cards { display: none; }
  [data-theme='dark'] .am-container-infinite-menu { display: initial; }
</style>
