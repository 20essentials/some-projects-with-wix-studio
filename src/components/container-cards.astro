---
import { arrayCards } from '@/utils/data';
import { baseUrl } from '@/utils/functions';
---

<section class='am-container-cards snapted'>
  {
    arrayCards
      .toSorted(() => Math.random() - 0.5)
      .map(({ id, localImage, repo, title }) => (
        <a class='card' href={repo} target='_blank'>
          <img src={baseUrl(localImage)} alt={title} loading='lazy' />
        </a>
      ))
  }
</section>

<style>
  .am-container-cards {
    min-height: 100vh;
    display: grid;
    padding: 2.2vmax;
    gap: 2.2vmax;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(20vmax, 1fr));
    position: relative;
    z-index: 10;

    img {
      width: 100%;
      height: 100%;
      aspect-ratio: 16 / 9;
      object-fit: cover;
    }
  }
</style>
